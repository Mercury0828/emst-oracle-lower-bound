import math, random

class DSU:
    def __init__(self,n):
        self.p=list(range(n)); self.sz=[1]*n; self.c=n
    def find(self,x):
        while self.p[x]"'!=x:
            self.p[x]=self.p[self.p[x]]; x=self.p[x]
        return x
    def union(self,a,b):
        ra,rb=self.find(a),self.find(b)
        if ra==rb: return
        if self.sz[ra]<self.sz[rb]: ra,rb=rb,ra
        self.p[rb]=ra; self.sz[ra]+=self.sz[rb]; self.c-=1

def comp_count(points, lam):
    n=len(points); d=DSU(n); L2=lam*lam
    for i in range(n):
        xi,yi=points[i]
        for j in range(i+1,n):
            xj,yj=points[j]
            if (xi-xj)**2+(yi-yj)**2 <= L2 + 1e-9:
                d.union(i,j)
    return d.c

def report(name, pts, lams):
    n=len(pts); floor=n**(1/3)
    print(name, '"'n=', n, 'n"'^(1/3)='"', round(floor,3))
    for lam in lams:
        c=comp_count(pts, lam)
        cost=min(n/c, math.sqrt(c))
        print('  lambda=', lam, 'c=', c, 'mincost=', round(cost,3))

