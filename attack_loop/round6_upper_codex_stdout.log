for k in range(24):
    bx=(k%6)*50; by=(k//6)*50
    for t in range(6): islands.append((bx+t%3, by+t//3))
report('islands', islands, [1.5, 10, 60])

random.seed(1)
rnd=[(random.randrange(144), random.randrange(144)) for _ in range(144)]
report('random', rnd, [4,8,16])

